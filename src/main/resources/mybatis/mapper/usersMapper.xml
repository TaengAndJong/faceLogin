<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ai.facelogin.users.mapper.UsersDao">


    <select id="getUser" resultMap="UserResultMap">
        SELECT * FROM users WHERE user_id_str = #{userIdStr}
    </select>

    <insert id="insertUser" parameterType="UserVO">
        insert into users
            (
                user_id_str,
                email,
                username,
                gender,
                agree_state
            ) values
            (
                #{userIdStr},
                #{email},
                #{username},
                #{gender},
                #{agree_state}
           )
    </insert>

</mapper>