<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ai.facelogin.face.mapper.FaceDao">

    <insert id="insertFace" parameterType="FaceVO">
        insert into facevector
        (
            face_id,
            user_id,
            face_encoding
        ) values
            (
                #{faceId},
                #{userId},
                #{faceEncoding}::vector --숫자배열 데이터를 pgvector 전용 형식인 vector 타입으로 변환
            )
    </insert>

</mapper>